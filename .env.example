# ===========================================
# Environment Variables for Development
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env
#
# For GitHub Actions CI/CD, configure these as Repository Secrets:
# Settings > Secrets and variables > Actions > New repository secret
# ===========================================

# -------------------------------------------
# NewsAPI Provider
# -------------------------------------------
# Get your API key at: https://newsapi.org/
NEWSAPI_KEY=your-newsapi-key-here
NEWSAPI_BASE_URL=https://newsapi.org/v2/

# -------------------------------------------
# CoinGecko Provider
# -------------------------------------------
# API docs: https://www.coingecko.com/en/api/documentation
COINGECKO_BASE=https://api.coingecko.com/api/v3
COINGECKO_SIMPLE_PRICE_PATH=/simple/price
COINGECKO_MARKET_CHART_PATH=/coins/{id}/market_chart
COINGECKO_VS_CURRENCY=usd

# -------------------------------------------
# RapidAPI Provider (Optional)
# -------------------------------------------
# If using alternative news provider
RAPID_NEWS_BASE_URL=https://crypto-news16.p.rapidapi.com/
RAPID_NEWS_PATH=/news/yahoo
RAPID_NEWS_HOST=crypto-news16.p.rapidapi.com
RAPID_NEWS_KEY=your-rapidapi-key-here
